# Shared secret — must match the integration's "Secret key". Use 32+ random chars.
QR_SERVICE_SECRET=change-me-to-a-long-random-secret

# Address to listen on.
BIND_ADDR=0.0.0.0:8723

# Path to the ffmpeg binary.
FFMPEG_PATH=ffmpeg

# Optional hardware-accelerated decode passed to ffmpeg as "-hwaccel <value>".
# Requires an ffmpeg build + drivers that support it (GPU passthrough).
#   NVIDIA: cuda      AMD/Intel on Linux: vaapi      Intel: qsv
# FFMPEG_HWACCEL=vaapi
#
# For VAAPI (AMD/Intel) also point at the render node and give the container
# access to it (Docker: --device /dev/dri).
# FFMPEG_HWACCEL_DEVICE=/dev/dri/renderD128

# Optional log filter.
# RUST_LOG=qr_vision_service=debug,info
